ile", "started_at": "2026-03-13T20:26:19.055424Z", "completed_at": "2026-03-13T20:26:19.071339Z"}, {"name": "execute", "started_at": "2026-03-13T20:26:19.071771Z", "completed_at": "2026-03-13T20:26:19.071777Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.030304670333862305, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.fluxcart_dbt.stg_inventory", "compiled": true, "compiled_code": "\n-- staging views for inventory\n-- Source table: raw_inventory (RAW schema)\nSELECT\n    timestamp AS inventory_time,\n    order_events,\n    units_ordered,\n    units_delivered,\n    units_cancelled,\n    fulfillment_rate,\n    top_warehouse,\n    top_product,\n    top_category,\n    orders_placed,\n    orders_delivered,\n    orders_cancelled\nFROM FLUXCART.RAW.raw_inventory\n\n-- Filters out rows with zero order_events.\n-- Standardizes numeric types for proper aggregation in marts.", "relation_name": "FLUXCART.DEV.stg_inventory", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-13T20:26:19.046694Z", "completed_at": "2026-03-13T20:26:19.072662Z"}, {"name": "execute", "started_at": "2026-03-13T20:26:19.073069Z", "completed_at": "2026-03-13T20:26:19.073075Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.03250455856323242, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.fluxcart_dbt.stg_fraud", "compiled": true, "compiled_code": "\n\n-- staging views for fraud data\n-- Source table: raw_fraud_alerts (RAW schema)\nSELECT\n    timestamp AS alert_time,           \n    alert_id,\n    rule,\n    severity,\n    user_id,\n    payment_id,\n    order_id,\n    amount,\n    detail\nFROM FLUXCART.RAW.raw_fraud\n\n--Only keeps rows with valid alert_id.\n--Converts amount to float.", "relation_name": "FLUXCART.DEV.stg_fraud", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-13T20:26:19.092077Z", "completed_at": "2026-03-13T20:26:19.098326Z"}, {"name": "execute", "started_at": "2026-03-13T20:26:19.098981Z", "completed_at": "2026-03-13T20:26:19.098992Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.022802352905273438, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.fluxcart_dbt.fct_analytics", "compiled": true, "compiled_code": "\n---- incremental table\n---- merge new rows\n-- unique per row\n\nWITH cleaned AS (\n    SELECT\n        event_time,\n        behavior_events,\n        top_action,\n        top_product,\n        top_category,\n        order_events,\n        avg_order_value,\n        total_revenue,\n        orders_placed,\n        orders_delivered,\n        orders_cancelled\n    FROM FLUXCART.DEV.stg_analytics       -- staging view\n)\n\nSELECT *\nFROM cleaned\n\n\nWHERE event_time > (SELECT MAX(event_time) FROM FLUXCART.DEV.fct_analytics)\n", "relation_name": "FLUXCART.DEV.fct_analytics", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-13T20:26:19.088442Z", "completed_at": "2026-03-13T20:26:19.099953Z"}, {"name": "execute", "started_at": "2026-03-13T20:26:19.100362Z", "completed_at": "2026-03-13T20:26:19.100368Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.024606943130493164, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.fluxcart_dbt.fct_fraud", "compiled": true, "compiled_code": "\n\nWITH cleaned AS (\n    SELECT\n        alert_id,\n        alert_time,\n        rule,\n        severity,\n        user_id,\n        payment_id,\n        order_id,\n        amount,\n        detail\n    FROM FLUXCART.DEV.stg_fraud\n)\n\nSELECT *\nFROM cleaned\n\n\nWHERE alert_time > (SELECT MAX(alert_time) FROM FLUXCART.DEV.fct_fraud)\n", "relation_name": "FLUXCART.DEV.fct_fraud", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-13T20:26:19.078336Z", "completed_at": "2026-03-13T20:26:19.101002Z"}, {"nam