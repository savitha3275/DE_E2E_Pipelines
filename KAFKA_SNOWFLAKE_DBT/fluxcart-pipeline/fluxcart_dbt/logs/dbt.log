    TRY_CAST(timestamp AS TIMESTAMP_NTZ) AS event_ts,
    TRY_CAST(behavior_events AS INT) AS behavior_events,
    top_action,
    top_product,
    top_category,
    TRY_CAST(order_events AS INT) AS order_events,
